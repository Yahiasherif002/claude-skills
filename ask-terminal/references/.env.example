# Server-side only — never exposed to the browser. Add to .gitignore.
# Any OpenAI-compatible chat-completions API works. Default is OpenRouter.
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=
# Pick any model the key can access. Free options: https://openrouter.ai/models?max_price=0
LLM_MODEL=openai/gpt-oss-120b:free
